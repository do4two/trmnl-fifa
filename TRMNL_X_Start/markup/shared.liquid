{% comment %}
  TRMNL X starter shared markup.
  Increase --starter-revision whenever this file changes.
{% endcomment %}
<style>
  .x-canvas {
    --starter-revision: 20260622-1;
    box-sizing: border-box;
    display: flex;
    flex: 1 1 100%;
    flex-direction: column;
    align-self: stretch;
    width: 100%;
    height: 100%;
    min-width: 0;
    min-height: 0;
    padding: 1.2cqw;
    gap: 1cqh;
    overflow: hidden;
    background: #fff;
    color: #000;
    font-family: "Inter Variable", Inter, Arial, sans-serif;
  }

  .trmnl .layout > .x-canvas {
    flex: 1 1 100% !important;
    align-self: stretch !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
    max-height: 100% !important;
  }

  .x-canvas *,
  .x-canvas *::before,
  .x-canvas *::after {
    box-sizing: border-box;
  }

  .x-header,
  .x-footer {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1cqw;
    min-width: 0;
  }

  .x-header {
    padding-bottom: 0.6cqh;
    border-bottom: 2px solid #000;
  }

  .x-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: clamp(14px, 2.2cqw, 32px);
    font-weight: 700;
  }

  .x-meta,
  .x-footer {
    font-size: clamp(10px, 1.25cqw, 18px);
  }

  .x-meta {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: right;
  }

  .x-content {
    flex: 1 1 auto;
    display: grid;
    place-items: center;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    border: 2px solid #000;
  }

  .x-content-inner {
    width: min(88%, 720px);
    text-align: center;
  }

  .x-value {
    font-size: clamp(28px, 8cqw, 96px);
    line-height: 1;
    font-weight: 700;
  }

  .x-description {
    margin-top: 1cqh;
    font-size: clamp(12px, 2cqw, 28px);
  }

  .x-footer {
    padding-top: 0.6cqh;
    border-top: 2px solid #000;
  }
</style>
