<div class="layout layout--col">
  <div class="x-canvas x-full">
    <div class="x-header">
      <span class="x-title">TRMNL X Starter · Full</span>
      <span class="x-meta">{{ updated_at | default: "Preview" }}</span>
    </div>

    <div class="x-content">
      <div class="x-content-inner">
        <div class="x-value">{{ value | default: "100%" }}</div>
        <div class="x-description">
          Dieser Canvas füllt den vollständigen TRMNL-X-View.
        </div>
      </div>
    </div>

    <div class="x-footer">
      <span>Full</span>
      <span>Layout → Canvas</span>
    </div>
  </div>
</div>
